def  is_name_taken(name: str, surname: str, loaded_data: list[dict]) -> bool: #7
    name = name.strip().lower()
    surname = surname.strip().lower()

    if not name or not surname:
        return False

    return any(
        isinstance(user.get("name"), str) and
        isinstance(user.get("surname"), str) and
        user["name"].strip().lower() == name and
        user["surname"].strip().lower() == surname
        for user in loaded_data
    )
def show_one_user(user: dict) -> None: #8
    if not user:
        print("No user data to display")
        return

    print("========== USER ==========")
    print(f"ID:        {user.get('id', 'N/A')}")
    print(f"Name:      {user.get('name', 'N/A')}")
    print(f"Surname:   {user.get('surname', 'N/A')}")
    print(f"DOB:       {user.get('date_of_birth', 'N/A')}")

    grades = user.get("grades", [])
    if grades:
        print(f"Grades:    {grades}")
        avg = sum(grades) / len(grades)
        print(f"Average:   {avg:.2f}")
    else:
        print("Grades:    No grades")

    print("==========================")

