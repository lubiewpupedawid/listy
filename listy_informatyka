3 - Replace all grades
            """)

            choice = input("- ").strip()

            if choice == "1":
                try:
                    grade = float(input("Enter new grade: "))
                    user.setdefault("grades", []).append(grade)
                except ValueError:
                    print("Invalid grade")

            elif choice == "2":
