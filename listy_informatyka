def best_student_in_subject(data: list[dict], subject: str) -> dict | None: #15
    key = f"grades {subject.lower()}"
    
    best_user = None
    best_avg = None

    for user in data:
        grades = user.get(key, [])
        
        if not grades:
            continue
        
        avg = sum(grades) / len(grades)
        
        if best_avg is None or avg > best_avg:
            best_avg = avg
            best_user = user

    return best_user

def subject_average_for_all_users(data: list[dict], subject: str) -> float | None: #16
    key = f"grades {subject.lower()}"
    
    all_grades = []
    
    for user in data:
        grades = user.get(key, [])
        all_grades.extend(grades)
    
    if not all_grades:
        return None
    
    return sum(all_grades) / len(all_grades)
