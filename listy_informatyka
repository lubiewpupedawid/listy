                        user["grades"].remove(grade)
                    else:
                        print("Grade not found")
                except ValueError:
                    print("Invalid grade")

            elif choice == "3":
                grades_input = input("Enter grades separated by space: ")
                try:
                    user["grades"] = [float(g) for g in grades_input.split()]
                except ValueError:
                    print("Invalid input")

            else:
                print("Invalid option")

