def add_or_remove_grades(data: list[dict])->None: #0
    name = input("Enter student name: ").strip()

    # find student
    for user in data:
        if user.get("name", "").lower() == name.lower():

            print(f"Current grades: {user.get('grades', [])}")

            print("""
What do you want to do?
