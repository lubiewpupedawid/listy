import datetime

def update_user_birth_date(data: list[dict], user_id: int, new_birth_date: str) -> bool: #6
    new_birth_date = new_birth_date.strip()

    
    try:
        datetime.datetime.strptime(new_birth_date, "%Y-%m-%d")
    except ValueError:
        return False

    for user in data:
        if user.get("id") == user_id:
            user["date_of_birth"] = new_birth_date
