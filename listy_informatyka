def find_user_by_id(data: list[dict], user_id: int) -> dict | None: #1
    for user in data:
        if user.get("id") == user_id:
            return user
    return None
def find_users_by_name(data: list[dict], name: str) -> list[dict]: #2
    # normalize input
    name = name.strip().lower()

    if not name:
        return []

    return [
        user for user in data
        if isinstance(user.get("name"), str)
        and user.get("name").strip().lower() == name
    ]

def delete_user_by_id(data: list[dict], user_id: int) -> bool:#3
    for i, user in enumerate(data):
        if user.get("id") == user_id:
            del data[i]
            return True
    return False

def update_user_name(user_id: int, new_name: str, loaded_data: list[dict]) -> bool: #4
    new_name = new_name.strip()

    if not new_name:
        return False  

    for user in loaded_data:
        if user.get("id") == user_id:
            user["name"] = new_name
            return True

    return False  

